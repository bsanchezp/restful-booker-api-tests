    {
      "name": "booking",
      "item": [
        {
          "name": "create booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Existe bookingid\", function () {\r",
                  "    pm.expect(json.bookingid).to.be.a(\"number\");\r",
                  "});\r",
                  "\r",
                  "// Guardar el id para los siguientes requests\r",
                  "pm.environment.set(\"booking_id\", json.bookingid);\r",
                  "\r",
                  "pm.test(\"Booking contains required fields\", function () {\r",
                  "    pm.expect(json.booking).to.have.property(\"firstname\");\r",
                  "    pm.expect(json.booking).to.have.property(\"lastname\");\r",
                  "    pm.expect(json.booking).to.have.property(\"totalprice\");\r",
                  "    pm.expect(json.booking).to.have.property(\"depositpaid\");\r",
                  "    pm.expect(json.booking).to.have.property(\"bookingdates\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Data types are correct\", function () {\r",
                  "    pm.expect(json.booking.firstname).to.be.a(\"string\");\r",
                  "    pm.expect(json.booking.lastname).to.be.a(\"string\");\r",
                  "    pm.expect(json.booking.totalprice).to.be.a(\"number\");\r",
                  "    pm.expect(json.booking.depositpaid).to.be.a(\"boolean\");\r",
                  "\r",
                  "    pm.expect(json.booking.bookingdates.checkin).to.be.a(\"string\");\r",
                  "    pm.expect(json.booking.bookingdates.checkout).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking data is correct\", function () {\r",
                  "    pm.expect(json.booking.firstname).to.eql(\"Beatriz\");\r",
                  "    pm.expect(json.booking.lastname).to.eql(\"Sanchez\");\r",
                  "    pm.expect(json.booking.totalprice).to.eql(500);\r",
                  "    pm.expect(json.booking.depositpaid).to.eql(true);\r",
                  "});\r",
                  "\r",
                  "const schema = {\r",
                  "    type: \"object\",\r",
                  "    required: [\"bookingid\", \"booking\"],\r",
                  "    properties: {\r",
                  "        bookingid: {\r",
                  "            type: \"number\"\r",
                  "        },\r",
                  "        booking: {\r",
                  "            type: \"object\",\r",
                  "            required: [\r",
                  "                \"firstname\",\r",
                  "                \"lastname\",\r",
                  "                \"totalprice\",\r",
                  "                \"depositpaid\",\r",
                  "                \"bookingdates\"\r",
                  "            ],\r",
                  "            properties: {\r",
                  "                firstname: {\r",
                  "                    type: \"string\"\r",
                  "                },\r",
                  "                lastname: {\r",
                  "                    type: \"string\"\r",
                  "                },\r",
                  "                totalprice: {\r",
                  "                    type: \"number\"\r",
                  "                },\r",
                  "                depositpaid: {\r",
                  "                    type: \"boolean\"\r",
                  "                },\r",
                  "                bookingdates: {\r",
                  "                    type: \"object\",\r",
                  "                    required: [\"checkin\", \"checkout\"],\r",
                  "                    properties: {\r",
                  "                        checkin: {\r",
                  "                            type: \"string\"\r",
                  "                        },\r",
                  "                        checkout: {\r",
                  "                            type: \"string\"\r",
                  "                        }\r",
                  "                    }\r",
                  "                },\r",
                  "                additionalneeds: {\r",
                  "                    type: \"string\"\r",
                  "                }\r",
                  "            }\r",
                  "        }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Schema de creación válido\", function () {\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\": \"Beatriz\",\r\n    \"lastname\": \"Sanchez\",\r\n    \"totalprice\": 500,\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2026-08-01\",\r\n        \"checkout\": \"2026-08-10\"\r\n    },\r\n    \"additionalneeds\": \"Breakfast\"\r\n}",
